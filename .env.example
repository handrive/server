# Database
DATABASE_URL=postgres://user:password@localhost:5432/handrive
DB_POOL_SIZE=20

# JWT (secret must be at least 32 characters)
JWT_SECRET=your-secret-key-at-least-32-characters-long
JWT_ACCESS_TTL_SECS=900
JWT_REFRESH_TTL_SECS=604800

# Server
HOST=0.0.0.0
PORT=3001
CORS_ORIGINS=http://localhost:3000
# TEST_MODE=false

# NATS (generate with: nk -gen account)
NATS_URL=nats://localhost:4222
NATS_PUBLIC_URL=tls://api.handrive.ai:4222
NATS_ACCOUNT_SIGNING_KEY=SA...
NATS_ACCOUNT_PUBLIC_KEY=A...

# Identity credential signing (Ed25519)
# Generate with: openssl rand -base64 32
# If not set, generates ephemeral keypair (not recommended for production)
IDENTITY_SIGNING_KEY=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# Apple Sign In OAuth (optional - required for iOS App Store)
# Get these from Apple Developer Console > Certificates, Identifiers & Profiles > Keys
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_REDIRECT_URI=http://localhost:3001/auth/apple/callback

# Resend for email OTP (get API key from resend.com)
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM=Handrive <noreply@handrive.ai>

# Logging
LOG_LEVEL=info
# LOG_DIR=/var/log/handrive
# LOG_FILE_PREFIX=handrive-server
# LOG_RETENTION_DAYS=7

# Cleanup interval for expired OTPs and sessions (default: 43200 = 12 hours)
# CLEANUP_INTERVAL_SECS=43200
